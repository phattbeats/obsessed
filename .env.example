# Obsessed - Environment Variables
# Copy this to .env and fill in your values

# LiteLLM API key (required for question generation)
# Point to your LiteLLM proxy instance
LITELLM_API_KEY=sk-your-litellm-key-here

# LiteLLM base URL (optional, defaults to http://10.0.0.100:4000)
LITELLM_BASE=http://10.0.0.100:4000

# Google Places API key (optional, for place scraping)
GOOGLE_PLACES_API_KEY=your-google-places-key

# OpenWeather API key (optional, for weather data)
OPENWEATHER_API_KEY=your-openweather-key


# Twitter/X cookie auth (required for twitter_handle scraping via twitter-cli)
# Get cookies from twitter.com → DevTools → Application → Cookies → twitter.com
# auth_token: main session cookie
# ct0: CSRF token (needed for full read access)
TWITTER_AUTH_TOKEN=your_auth_token_here
TWITTER_CT0=your_ct0_here


# Facebook Page scrape (optional — for deeper FB data beyond public page)
# Set FACEBOOK_DEEP_SCRAPE_ENABLED=true and provide cookie values to enable
# the FaustRen/facebook-graphql-scraper path (via browserless:3000).
# Default behavior: only the public-page crawl4ai path is used.
FACEBOOK_DEEP_SCRAPE_ENABLED=false
FACEBOOK_C_USER=          # c_user cookie from facebook.com
FACEBOOK_XS=             # xs cookie from facebook.com
