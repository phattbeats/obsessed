# Obsessed - Environment Variables
# Copy this to .env and fill in your values

# LiteLLM API key (required for question generation)
# Point to your LiteLLM proxy instance
LITELLM_API_KEY=sk-your-litellm-key-here

# LiteLLM base URL (optional, defaults to http://10.0.0.100:4000)
LITELLM_BASE=http://10.0.0.100:4000

# Google Places API key (optional, for place scraping)
GOOGLE_PLACES_API_KEY=your-google-places-key

# OpenWeather API key (optional, for weather data)
OPENWEATHER_API_KEY=your-openweather-key


# Twitter/X cookie auth (required for twitter_handle scraping via twitter-cli)
# Get cookies from twitter.com → DevTools → Application → Cookies → twitter.com
# auth_token: main session cookie
# ct0: CSRF token (needed for full read access)
TWITTER_AUTH_TOKEN=your_auth_token_here
TWITTER_CT0=your_ct0_here


# Facebook Page scrape (optional — for deeper FB data beyond public page)
# Set FACEBOOK_DEEP_SCRAPE_ENABLED=true and provide cookie values to enable
# the FaustRen/facebook-graphql-scraper path (via browserless:3000).
# Default behavior: only the public-page crawl4ai path is used.
FACEBOOK_DEEP_SCRAPE_ENABLED=false
FACEBOOK_C_USER=          # c_user cookie from facebook.com
FACEBOOK_XS=             # xs cookie from facebook.com

# Steam Web API key (optional — free at steamcommunity.com/dev/apikey)
# Required for full game library enrichment; without it only basic XML profile is fetched.
STEAM_API_KEY=your_steam_api_key_here

# Admin token (optional — defaults to empty = open access)
# Set ADMIN_TOKEN to require `Authorization: Bearer <token>` on all /api/admin/* routes.
# Leave empty for single-host LAN/VPN deployments where the FastAPI port is not publicly exposed.
# Crawl4AI bearer token (required if your crawl4ai service is configured to require auth)
# Leave empty when running against an unauthenticated local crawl4ai (default in dev).
CRAWL4AI_TOKEN=

# Admin endpoint gate (REQUIRED if Obsessed is reachable from the public internet).
# When set, every /api/admin/* request must include `Authorization: Bearer <ADMIN_TOKEN>`.
# Empty (default) leaves admin routes open — only acceptable on LAN/VPN-only deployments.
# Generate a strong value:  openssl rand -hex 32
ADMIN_TOKEN=

# 2Captcha solver API key (optional — only needed for the walls FlareSolverr can't crack).
# Used by app/services/scraper/captcha_solver.py for reCAPTCHA v2 (Ohio Voter Lookup)
# and DataDome (TruePeopleSearch, Legacy.com obituaries). ~$2–3 per 1000 solves.
# Get a key at https://2captcha.com — leave empty to disable the solver.
TWOCAPTCHA_API_KEY=

# DataDome solve proxy (optional — only for TruePeopleSearch / Legacy.com obits).
# DataDome binds the solved cookie to the IP that solved it, so the 2Captcha solve
# AND the data requests must share one exit IP. When set, ALL requests to those
# sites route through this proxy. Format: HOST:PORT or USER:PASS@HOST:PORT (scheme
# optional, defaults http). Leave empty to keep the DataDome path dormant — the app
# stays fully standalone and people-search falls back to FastPeopleSearch.
# On PHATT-RAID the existing privoxy works: DATADOME_SOLVE_PROXY=10.0.0.100:8118
DATADOME_SOLVE_PROXY=

# Hard cap on 2Captcha DataDome solves per process restart (guards balance). Default 5.
DATADOME_MAX_SOLVES_PER_RUN=5
